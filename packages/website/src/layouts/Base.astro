---
interface Props {
  title?: string;
}

const { title = 'AgentQuilt' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="AgentQuilt: Git-native framework for maintaining AI agent instructions as structured, composable source files." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Git-native framework for maintaining AI agent instructions as structured, composable source files." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
    <!-- Fonts self-hosted — no third-party requests, GDPR safe -->
    <style is:global>
      @import '@fontsource-variable/geist/index.css';
      @import '@fontsource-variable/geist-mono/index.css';
      /* Alias variable font names so inline-style references like font-family:'Geist' resolve correctly */
      @font-face{font-family:'Geist';src:local('Geist Variable');font-weight:100 900;font-style:normal}
      @font-face{font-family:'Geist Mono';src:local('Geist Mono Variable');font-weight:100 900;font-style:normal}

      *{box-sizing:border-box}
      html{scroll-behavior:smooth}
      html,body{margin:0;padding:0;background:#070a14}
      ::selection{background:#5b8cff;color:#fff}
      :root,[data-theme="dark"]{
        --bg:#070a14;--surface:#0d1220;--raised:#131a2c;--border:#212a44;--seam:#1a2138;
        --fg:#e9edf6;--muted:#8b95ad;--faint:#59627d;
        --accent:#5b8cff;--cyan:#4fd0ff;--purple:#9b6cff;--on-accent:#ffffff;
        --grad:linear-gradient(120deg,#4fd0ff 0%,#5b8cff 46%,#9b6cff 100%);
        --accent-soft:rgba(91,140,255,.12);
        --term-bg:#080b15;--term-seam:#161d30;
        --term-text:#c9ced6;--term-label:#6a7285;
      }
      [data-theme="light"]{
        --bg:#f5f7fc;--surface:#ffffff;--raised:#eef1f8;--border:#dde3ef;--seam:#e6ebf5;
        --fg:#0d1220;--muted:#525a70;--faint:#8b93a8;
        --accent:#3f6fe0;--cyan:#1a9fd4;--purple:#7c4fe0;--on-accent:#ffffff;
        --grad:linear-gradient(120deg,#1a9fd4 0%,#3f6fe0 46%,#7c4fe0 100%);
        --accent-soft:rgba(63,111,224,.10);
        --term-bg:#eef1f8;--term-seam:#dde3ef;
        --term-text:#374561;--term-label:#8295b5;
      }
      body{
        font-family:'Geist',system-ui,sans-serif;
        background-color:var(--bg);
        color:var(--fg);
        -webkit-font-smoothing:antialiased;
        overflow-x:hidden;
        transition:background-color .25s ease,color .25s ease;
      }
      @keyframes blink{0%,49%{opacity:1}50%,100%{opacity:0}}
      @keyframes fadeup{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
      @media(max-width:900px){ .nav-links{display:none !important} }
      @media(max-width:820px){ .hero-tree{display:none !important} }

      /* Hover utilities — replace inline onmouseover handlers */
      .hover-fg:hover{color:var(--fg) !important}
      .hover-border-accent:hover{border-color:var(--accent) !important}
      .hover-qs-row:hover{background:color-mix(in srgb,var(--accent) 7%,transparent) !important}
      .feature-card:hover{border-top-color:var(--accent) !important;background:color-mix(in srgb,var(--accent) 5%,transparent) !important}
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
