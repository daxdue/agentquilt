---
interface Props {
  title?: string;
}

const { title = 'AgentQuilt' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="AgentQuilt: Git-native framework for maintaining AI agent instructions as structured, composable source files." />
    <title>{title}</title>
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

      body {
        font-family: 'Inter', sans-serif;
      }
    </style>
  </head>
  <body class="bg-gray-950 text-gray-100">
    <slot />
  </body>
</html>
