---
---

<section id="start" style="max-width:1220px;margin:0 auto;padding:52px 28px 92px;border-top:1px solid var(--border)">
  <div style="display:flex;flex-wrap:wrap;gap:52px;align-items:center;justify-content:space-between">

    <div style="flex:1 1 330px;min-width:0">
      <p style="font-family:'Geist',sans-serif;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin:0 0 16px">Quickstart</p>
      <h2 style="font-size:clamp(30px,4vw,44px);font-weight:800;letter-spacing:-0.03em;margin:0 0 16px;line-height:1.05">Author &rarr; build &rarr; check.<br>In under a minute.</h2>
      <p style="font-size:17px;line-height:1.6;color:var(--muted);max-width:420px;margin:0 0 28px">
        Install once, scaffold in your repo, then commit sources and generated outputs together. Node &ge; 18 &middot; open source &middot; MIT.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center">
        <a href="https://github.com/daxdue/agentquilt" style="font-family:'Geist',sans-serif;font-weight:700;font-size:14px;background:var(--grad);color:#fff;border-radius:11px;padding:13px 22px;text-decoration:none;box-shadow:0 10px 26px -12px rgba(91,140,255,.8);display:inline-flex;align-items:center;gap:9px">
          <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          Star on GitHub
        </a>
        <a href="#code" class="hover-border-accent" style="font-family:'Geist',sans-serif;font-weight:700;font-size:14px;background:var(--surface);border:1px solid var(--border);color:var(--fg);border-radius:11px;padding:13px 22px;text-decoration:none;transition:border-color .15s ease">Read the docs &rarr;</a>
      </div>
    </div>

    <div style="flex:1 1 440px;min-width:0">
      <div style="background:var(--term-bg);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 24px 60px -30px rgba(0,0,0,.7)">
        <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;border-bottom:1px solid var(--term-seam)">
          <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#febc2e"></span>
          <span style="width:10px;height:10px;border-radius:50%;background:#28c840"></span>
          <span style="margin:0 auto;font-family:'Geist Mono',monospace;font-size:12px;color:var(--term-label)">quickstart</span>
        </div>
        <div style="font-family:'Geist Mono',monospace;font-size:13.5px;line-height:1.5">
          <div class="hover-qs-row" style="display:flex;align-items:center;gap:16px;padding:16px 20px;border-bottom:1px solid var(--term-seam);transition:background .15s ease">
            <span style="color:var(--faint);width:12px;flex:none">1</span>
            <span style="color:#c9ced6"><span style="color:var(--accent)">$</span> npm install -g agentquilt</span>
          </div>
          <div class="hover-qs-row" style="display:flex;align-items:center;gap:16px;padding:16px 20px;border-bottom:1px solid var(--term-seam);transition:background .15s ease">
            <span style="color:var(--faint);width:12px;flex:none">2</span>
            <span style="color:#c9ced6"><span style="color:var(--accent)">$</span> agentquilt init --platform claude</span>
          </div>
          <div class="hover-qs-row" style="display:flex;align-items:center;gap:16px;padding:16px 20px;border-bottom:1px solid var(--term-seam);transition:background .15s ease">
            <span style="color:var(--faint);width:12px;flex:none">3</span>
            <span style="color:#c9ced6"><span style="color:var(--accent)">$</span> agentquilt agents add reviewer</span>
          </div>
          <div class="hover-qs-row" style="display:flex;align-items:center;gap:16px;padding:16px 20px;transition:background .15s ease">
            <span style="color:var(--faint);width:12px;flex:none">4</span>
            <span style="color:#c9ced6"><span style="color:var(--accent)">$</span> agentquilt build&nbsp;&nbsp;<span style="color:var(--faint)"># &rarr; targets + lock</span></span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
