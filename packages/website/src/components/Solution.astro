---
---

<section class="py-24 px-6 bg-gradient-to-b from-transparent via-brand-950/10 to-transparent">
  <div class="max-w-4xl mx-auto space-y-16">
    <div class="space-y-4">
      <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-500/10 border border-green-500/40 rounded-full text-sm text-green-400">
        <span>✓</span>
        <span>THE SOLUTION</span>
      </div>
      <h2 class="text-5xl font-black">Fragment-based, platform-agnostic compilation</h2>
      <p class="text-lg text-gray-400">
        Write fragments once. Compile to any platform. One source of truth for all agent targets.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative space-y-8 mt-12">
      <!-- Timeline connector line -->
      <div class="absolute left-5 top-0 bottom-0 w-px bg-gradient-to-b from-brand-500 via-brand-500 to-transparent"></div>

      <!-- Step 1: Author -->
      <div class="relative pl-20 animate-on-scroll" style="animation-delay: 0ms;">
        <!-- Circle badge -->
        <div class="absolute -left-3.5 top-0 w-11 h-11 rounded-full bg-brand-600 border-4 border-gray-950 flex items-center justify-center font-bold text-white">
          1
        </div>

        <!-- Card -->
        <div class="glass rounded-xl p-6">
          <h3 class="text-2xl font-bold text-white mb-4">Author Fragments</h3>
          <p class="text-gray-400 mb-4">Write small Markdown files under <code class="bg-gray-800 px-2 py-1 rounded text-brand-300">agents/your-agent/</code>. One concern per file.</p>

          <div class="bg-gray-900/80 border border-gray-800 rounded-lg p-4 font-mono text-sm text-gray-300 overflow-x-auto">
            <pre><code><span class="text-gray-500">agents/coder/</span>
├── <span class="text-brand-400">010-role.md</span>
├── <span class="text-brand-400">020-tools.md</span>
└── <span class="text-brand-400">030-examples.md</span></code></pre>
          </div>
        </div>
      </div>

      <!-- Step 2: Build -->
      <div class="relative pl-20 animate-on-scroll" style="animation-delay: 100ms;">
        <div class="absolute -left-3.5 top-0 w-11 h-11 rounded-full bg-brand-600 border-4 border-gray-950 flex items-center justify-center font-bold text-white">
          2
        </div>

        <div class="glass rounded-xl p-6">
          <h3 class="text-2xl font-bold text-white mb-4">Compile to All Platforms</h3>
          <p class="text-gray-400 mb-4">Run <code class="bg-gray-800 px-2 py-1 rounded text-brand-300">agentquilt build</code> to validate and compile fragments into deterministic targets for every platform.</p>

          <div class="bg-gray-900/80 border border-gray-800 rounded-lg p-4 font-mono text-sm text-gray-300 overflow-x-auto">
            <pre><code><span class="text-gray-500">$ agentquilt build</span>
<span class="text-green-400">✓</span> .claude/agents/coder.md
<span class="text-green-400">✓</span> .cursor/rules/coder.mdc
<span class="text-green-400">✓</span> .github/copilot-instructions.md
<span class="text-gray-500">→ Version hash: 4a7f2e9d...</span></code></pre>
          </div>
        </div>
      </div>

      <!-- Step 3: Enforce -->
      <div class="relative pl-20 animate-on-scroll" style="animation-delay: 200ms;">
        <div class="absolute -left-3.5 top-0 w-11 h-11 rounded-full bg-brand-600 border-4 border-gray-950 flex items-center justify-center font-bold text-white">
          3
        </div>

        <div class="glass rounded-xl p-6">
          <h3 class="text-2xl font-bold text-white mb-4">Enforce with CI</h3>
          <p class="text-gray-400 mb-4"><code class="bg-gray-800 px-2 py-1 rounded text-brand-300">agentquilt check</code> fails the build if targets drift from source. Prevent stale agent files.</p>

          <div class="bg-gray-900/80 border border-gray-800 rounded-lg p-4 font-mono text-sm text-gray-300 overflow-x-auto">
            <pre><code><span class="text-gray-500">$ agentquilt check</span>
<span class="text-green-400">✓</span> CLAUDE.md up-to-date
<span class="text-green-400">✓</span> AGENTS.md up-to-date</span></code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- Benefit callout -->
    <div class="glass rounded-xl p-8 border-brand-500/20 mt-8">
      <p class="text-lg text-white leading-relaxed">
        <span class="text-green-400 font-bold">✓ No more conflicts. Platform consistency guaranteed.</span> Each developer edits separate fragments. Git merges naturally. One source of truth compiles to all platforms. Code reviews are readable. Agent changes are traceable across Claude, Cursor, Copilot, and internal targets.
      </p>
    </div>
  </div>
</section>
