---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-800 py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div class="space-y-4">
        <h3 class="font-bold text-white">AgentQuilt</h3>
        <p class="text-gray-400 text-sm">
          A Git-native framework for maintaining AI agent instructions as code.
        </p>
      </div>

      <div class="space-y-4">
        <h3 class="font-semibold text-white text-sm">Resources</h3>
        <ul class="space-y-2 text-gray-400">
          <li>
            <a
              href="https://github.com/daxdue/agentquilt"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              GitHub Repository
            </a>
          </li>
          <li>
            <a
              href="https://github.com/daxdue/agentquilt/blob/main/.docs/agentquilt-v1-spec.md"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              v1 Specification
            </a>
          </li>
          <li>
            <a
              href="https://github.com/daxdue/agentquilt/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              Issues & Feedback
            </a>
          </li>
        </ul>
      </div>

      <div class="space-y-4">
        <h3 class="font-semibold text-white text-sm">Legal</h3>
        <ul class="space-y-2 text-gray-400">
          <li>
            <a
              href="https://github.com/daxdue/agentquilt/blob/main/LICENSE"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              MIT License
            </a>
          </li>
          <li>
            <a
              href="https://github.com/daxdue"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-white transition"
            >
              GitHub Profile
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-500 text-sm">
        © {year} AgentQuilt. MIT License.
      </p>
      <p class="text-gray-500 text-sm mt-4 md:mt-0">
        Built with <span class="text-brand-400">Astro</span> and <span class="text-brand-400">Tailwind</span>
      </p>
    </div>
  </div>
</footer>
