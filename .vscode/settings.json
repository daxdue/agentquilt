{
  "files.associations": {
    "agent.yaml": "yaml",
    "*.yaml": "yaml"
  },
  "yaml.schemaStore.enable": true,
  "yaml.validate": true,
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "search.exclude": {
    "tools/agentquilt/node_modules": true,
    "tools/agentquilt/dist": true,
    "agents/*/generated": true
  },
  "files.exclude": {
    "tools/agentquilt/node_modules": true,
    "tools/agentquilt/dist": true,
    "agents/*/generated": true
  }
}
