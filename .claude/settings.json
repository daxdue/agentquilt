{
  "enabledPlugins": {
    "github@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Edit(/AGENTS.md)",
      "Write(/AGENTS.md)",
      "Edit(/CLAUDE.md)",
      "Write(/CLAUDE.md)",
      "Edit(/.claude/agents/**)",
      "Write(/.claude/agents/**)",
      "Edit(/agentquilt.lock)",
      "Write(/agentquilt.lock)",
      "Bash(git push*)",
      "Bash(git tag*)",
      "Bash(npm publish*)",
      "Bash(npm version*)",
      "Bash(gh pr merge*)",
      "Bash(gh release*)",
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Read(*.pem)",
      "Edit(*.pem)",
      "Write(*.pem)",
      "Read(*.key)",
      "Edit(*.key)",
      "Write(*.key)",
      "Read(id_rsa*)",
      "Edit(id_rsa*)",
      "Write(id_rsa*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/pretooluse-guard.sh"
          }
        ]
      }
    ]
  }
}
